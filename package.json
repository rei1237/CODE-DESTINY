{
  "name": "code-destiny-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "cross-env NEXT_VERSION=15.0.0 npx @opennextjs/cloudflare build",
    "build:cf:legacy": "npx @opennextjs/cloudflare build --dangerouslyUseUnsupportedNextVersion",
    "build:cf:static": "npm run build:cf && npm run deploy:cf:static",
    "deploy:cf:static": "node scripts/deploy-pages.mjs",
    "deploy:cf:static:prod": "node scripts/deploy-pages.mjs --branch main",
    "deploy:cf": "npm run build:cf && npx wrangler deploy --config wrangler.worker.jsonc",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "@opennextjs/cloudflare": "^1.6.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "wrangler": "^4.55.0"
  }
}
