{
  "name": "code-destiny-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "npx cross-env NEXT_VERSION=15.0.0 opennextjs-cloudflare build",
    "build:cf:legacy": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion",
    "build:cf:static": "node -e \"console.log('Cloudflare static deploy: no build step required')\"",
    "deploy:cf:static": "npx wrangler pages deploy . --project-name \"$CF_PAGES_PROJECT_NAME\" --branch \"${CF_PAGES_BRANCH:-main}\"",
    "deploy:cf:static:prod": "npx wrangler pages deploy . --project-name \"$CF_PAGES_PROJECT_NAME\" --branch main",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "wrangler": "^4.55.0"
  }
}
