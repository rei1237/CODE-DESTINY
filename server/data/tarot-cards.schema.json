{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-destiny.local/schemas/tarot-cards.schema.json",
  "title": "Tarot Card Database",
  "type": "object",
  "required": ["version", "source", "cards"],
  "properties": {
    "version": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": ["name", "url", "lastSyncedAt"],
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "lastSyncedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "nameKr",
          "arcanaType",
          "suit",
          "rank",
          "number",
          "keywords",
          "interpretations"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "nameKr": { "type": "string" },
          "arcanaType": {
            "type": "string",
            "enum": ["Major", "Minor"]
          },
          "suit": {
            "type": ["string", "null"],
            "enum": ["Wands", "Cups", "Swords", "Pentacles", null]
          },
          "rank": { "type": "string" },
          "number": { "type": "integer", "minimum": 0, "maximum": 21 },
          "imageKey": { "type": "string" },
          "symbols": {
            "type": "array",
            "items": { "type": "string" }
          },
          "keywords": {
            "type": "object",
            "required": ["upright", "reversed"],
            "properties": {
              "upright": {
                "type": "array",
                "items": { "type": "string" }
              },
              "reversed": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "interpretations": {
            "type": "object",
            "required": ["upright", "reversed"],
            "properties": {
              "upright": { "$ref": "#/$defs/categoryInterpretation" },
              "reversed": { "$ref": "#/$defs/categoryInterpretation" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "categoryInterpretation": {
      "type": "object",
      "required": ["general", "love", "money", "career"],
      "properties": {
        "general": { "type": "string" },
        "love": { "type": "string" },
        "money": { "type": "string" },
        "career": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
