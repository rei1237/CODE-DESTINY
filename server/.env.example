# Backend API server environment
API_PORT=4000

# MongoDB connection string (로컬 또는 Atlas)
# Atlas 예: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=AppName
MONGO_URI=mongodb://127.0.0.1:27017/code_destiny
MONGO_DB_NAME=code_destiny

# JWT settings
JWT_SECRET=please_change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Allowed frontend origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://code-destiny.com,https://www.code-destiny.com

# PortOne (iamport) payment verification
PORTONE_API_BASE_URL=https://api.iamport.kr
PORTONE_API_KEY=your_portone_api_key
PORTONE_API_SECRET=your_portone_api_secret

# Optional amount->points policy table (JSON object)
# If omitted, charged points defaults to payment amount (1 KRW = 1 point)
# Example: {"5000":5000,"10000":10500,"30000":33000}
POINT_CHARGE_PACKAGES={"5000":5000,"10000":10000}

# 운세 조회 1회 차감 포인트 (기본값: 1000)
DEFAULT_FORTUNE_COST_POINTS=1000
