# Cloudflare Pages deploy auth
# Recommended scope: Account.Cloudflare Pages:Edit + Account:Read
CLOUDFLARE_API_TOKEN=

# Optional alias supported by scripts/deploy-pages.mjs
# CF_API_TOKEN=

# Pages project settings
CF_PAGES_PROJECT_NAME=codedestiny
CF_PAGES_BRANCH=main

# Optional, useful for some wrangler commands
# CLOUDFLARE_ACCOUNT_ID=
